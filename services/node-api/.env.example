# ── Server ───────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── PostgreSQL (shared with go-metadata) ─
DATABASE_URL=postgres://postgres:postgres@localhost:5432/echoestate?sslmode=disable

# ── Redis ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (must match go-metadata JWT_SECRET exactly) ──
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_long_random_secret

# ── Cloudflare R2 ────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=echo-estate
# Public bucket URL (enable public access in R2 dashboard)
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ── RunPod ───────────────────────────────
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=lbqkin23xehi2k

# ── Go Metadata Service ───────────────────
METADATA_API_URL=http://localhost:8080
