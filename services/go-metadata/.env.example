# ── Go Metadata Service ──────────────────
GO_PORT=8080

# ── PostgreSQL ───────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/echoestate?sslmode=disable

# ── Redis ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────
# Must match NODE_JWT_SECRET in node-api/.env exactly
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRY_HOURS=24